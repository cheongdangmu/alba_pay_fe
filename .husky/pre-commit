#!/usr/bin/env sh

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -z "$staged_files" ]; then
  exit 0
fi

eslint_files="$(printf '%s\n' "$staged_files" | grep -E '\.(js|jsx|ts|tsx|mjs|cjs)$' || true)"
prettier_files="$(printf '%s\n' "$staged_files" | grep -E '\.(js|jsx|ts|tsx|mjs|cjs|json|md|css|scss|yml|yaml)$' || true)"

if [ -n "$eslint_files" ]; then
  printf '%s\n' "$eslint_files" | xargs pnpm exec eslint --fix
fi

if [ -n "$prettier_files" ]; then
  printf '%s\n' "$prettier_files" | xargs pnpm exec prettier --write
fi

printf '%s\n' "$staged_files" | xargs git add --